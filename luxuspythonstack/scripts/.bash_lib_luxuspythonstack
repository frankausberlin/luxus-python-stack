cw() {
    local _state_dir="$HOME/.config"
    local _state_file="$_state_dir/current_working_folder"
    local _target

    if [[ "${1:-}" == "." ]]; then
        mkdir -p "$_state_dir"
        printf '%s\n' "$PWD" > "$_state_file"
        return 0
    fi

    if [[ ! -f "$_state_file" ]]; then
        echo "No working folder saved. Run 'cw .' first." >&2
        return 1
    fi

    _target="$(<"$_state_file")"
    if [[ -z "$_target" || ! -d "$_target" ]]; then
        echo "Saved working folder is invalid: $_target" >&2
        return 1
    fi

    cd "$_target" || return 1
}

alias rlb="source ~/.bashrc"
alias pypurge='pip cache purge; mamba clean --all'

# act: activate a Mamba environment and persist it for new shells
act() {
    local _env_name="${1:-}"

    if [[ -z "$_env_name" ]]; then
        echo "Usage: act <envname>" >&2
        return 1
    fi

    echo "$_env_name" > "$HOME/.startenv"
    mamba activate "$_env_name"
}

# Resolve the directory of this lib file once at source time
_LUXUS_SCRIPTS_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"

# pyinit: wrapper that calls the standalone pyinit.sh script
pyinit() { bash "$_LUXUS_SCRIPTS_DIR/pyinit.sh" "$@"; }

# jl: start Jupyter Lab — sources launch_jupyter.sh to load its jl() function
source "$_LUXUS_SCRIPTS_DIR/launch_jupyter.sh"


EMOJIS=(🐧 🤐 🥴 🤢 🤮 🤧 😷 🤒 🤕 🤑 🤠 😈 👿 👹 👺 🤡 💩 👻 💀 ☠️ 👽 👾 🤖 🎃 😺 😸 😹 😻 )
RANDOM_EMOJI() { echo "${EMOJIS[$RANDOM % ${#EMOJIS[@]}]}"; }
python_info() {
    if [[ -n "$VIRTUAL_ENV" ]]; then
        echo "(venv: $(basename "$PWD"))"
    elif [[ -n "$CONDA_DEFAULT_ENV" ]]; then
        echo "(mamba: $CONDA_DEFAULT_ENV)"
    fi
}
# My smart PS1: shows random emoji, user@host, current folder, python env info
export VIRTUAL_ENV_DISABLE_PROMPT=1; prompt_user=$(whoami); prompt_host=$(hostname)
PS1='$(RANDOM_EMOJI) \[\033[1;32m\]╭──(\[\033[1;34m\]${prompt_user}@${prompt_host}\[\033[1;32m\])─[\[\033[1;37m\]\w\[\033[1;32m\]] \[\033[1;31m\]$(python_info)\[\033[0m\]
\[\033[1;32m\]╰─\[\033[1;34m\]\$\[\033[0m\] '
